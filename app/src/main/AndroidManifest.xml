<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- READ_CONTACTS: para no bloquear llamadas de contactos conocidos. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- INTERNET: sincronizar la base publica y enviar aportes a GitHub. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- El bloqueo se hace via CallScreeningService + ROLE_CALL_SCREENING (rol en runtime),
         que NO requiere READ_CALL_LOG ni permisos de telefono. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".OpenCallShieldApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenCallShield">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.OpenCallShield">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.SpamCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

    </application>

</manifest>
